{
  "name": "0waste",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @0waste/api db:generate",
    "db:migrate": "pnpm --filter @0waste/api db:migrate"
  },
  "devDependencies": {
    "turbo": "^2.9.6"
  },
  "pnpm": {
    "overrides": {
      "better-call": "1.3.5"
    },
    "ignoredBuiltDependencies": [
      "@prisma/client"
    ],
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
