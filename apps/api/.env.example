
# Postgres connection string (Neon, Docker, or local install)
# Local example: postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/zerowaste
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Neon (or any Postgres) connection string
#DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/zerowaste

# Better Auth — use a long random string in production (min 32 chars)
BETTER_AUTH_SECRET=

# Public URL of this API (no trailing slash), e.g. https://your-api.vercel.app
BETTER_AUTH_URL=http://localhost:3000

# Session cookies across origins (e.g. Expo web on :8081, API on :3000). Set to 1 for deployed SPA + API on different domains. Omit in dev to use the default (enabled). Set to 0 to force SameSite=Lax (same-origin only).
# BETTER_AUTH_CROSS_SITE_COOKIES=1

# Optional — dev server port (default 3000)
# PORT=3000
