{
  "name": "@0waste/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/dev.ts",
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . && prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "auth:generate": "better-auth generate --config auth.ts --output src/db/schema.ts -y",
    "db:seeds": "tsx --env-file=.env src/db/seeds.ts"
  },
  "dependencies": {
    "@0waste/spoonacular-api": "workspace:*",
    "@hono/node-server": "^2.0.0",
    "@trpc/server": "^11.16.0",
    "better-auth": "^1.6.5",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14",
    "postgres": "^3.4.7",
    "zod": "^4.3.6"
  },
  "prettier": "@0waste/prettier-config",
  "devDependencies": {
    "@0waste/eslint-config": "workspace:*",
    "@0waste/prettier-config": "workspace:*",
    "@better-auth/cli": "^1.4.21",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  }
}
